### --- PUBLIC (any authenticated user) ---

### List all stores
GET {{baseUrl}}/api/stores
Authorization: {{customerToken}}

###

### Get store by ID
GET {{baseUrl}}/api/stores/{{storeId}}
Authorization: {{customerToken}}

### --- OWNER ---

### Create store
POST {{baseUrl}}/api/stores
Authorization: {{ownerToken}}
Content-Type: application/json

{
  "name": "맛있는 치킨집",
  "address": "서울특별시 강남구 테헤란로 123",
  "phone": "02-1234-5678",
  "content": "바삭한 치킨 전문점입니다.",
  "storePictureUrl": null,
  "productCreatedTime": "09:00:00",
  "openedTime": "10:00:00",
  "closedTime": "22:00:00",
  "closedDays": "MONDAY"
}

###

### Get my store
GET {{baseUrl}}/api/stores/mine
Authorization: {{ownerToken}}

###

### Update store
PUT {{baseUrl}}/api/stores/{{storeId}}
Authorization: {{ownerToken}}
Content-Type: application/json

{
  "name": "맛있는 치킨집 (리뉴얼)",
  "address": "서울특별시 강남구 테헤란로 123",
  "phone": "02-1234-5678",
  "content": "더욱 바삭해진 치킨 전문점입니다.",
  "storePictureUrl": "https://example.com/store.jpg",
  "productCreatedTime": "08:00:00",
  "openedTime": "10:00:00",
  "closedTime": "23:00:00",
  "closedDays": "TUESDAY"
}

###

### Delete store
DELETE {{baseUrl}}/api/stores/{{storeId}}
Authorization: {{ownerToken}}
