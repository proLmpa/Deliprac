@baseUrl = http://localhost:8082
@storeId = 1
@productId = 2

### List products by store (public)
GET {{baseUrl}}/api/stores/{{storeId}}/products
Authorization: {{customerToken}}

### Get product by ID (public)
GET {{baseUrl}}/api/stores/{{storeId}}/products/{{productId}}
Authorization: {{customerToken}}

### Create product - 후라이드 치킨 (OWNER)
POST {{baseUrl}}/api/stores/{{storeId}}/products
Authorization: {{ownerToken}}
Content-Type: application/json

{
  "name": "후라이드 치킨",
  "description": "바삭바삭한 정통 후라이드 치킨입니다.",
  "price": 18000,
  "productPictureUrl": null
}

### Create product - 프라이드 치킨 (OWNER)
POST {{baseUrl}}/api/stores/{{storeId}}/products
Authorization: {{ownerToken}}
Content-Type: application/json

{
  "name": "프라이드 치킨",
  "description": "바삭바삭한 정통 후라이드 치킨입니다.",
  "price": 18000,
  "productPictureUrl": null
}

### Create product - 양념 치킨 (OWNER)
POST {{baseUrl}}/api/stores/{{storeId}}/products
Authorization: {{ownerToken}}
Content-Type: application/json

{
  "name": "양념 치킨",
  "description": "달콤하고 매콤한 양념 치킨입니다.",
  "price": 19000,
  "productPictureUrl": null
}

### Update product (OWNER)
PUT {{baseUrl}}/api/stores/{{storeId}}/products/{{productId}}
Authorization: {{ownerToken}}
Content-Type: application/json

{
  "name": "프라이드 치킨 (특대)",
  "description": "바삭바삭한 정통 후라이드 치킨 특대 사이즈입니다.",
  "price": 21000,
  "productPictureUrl": "https://example.com/chicken.jpg"
}

### Deactivate product (OWNER)
// PUT {{baseUrl}}/api/stores/{{storeId}}/products/{{productId}}/deactivate
// Authorization: {{ownerToken}}

### Get popular products for store (OWNER)
GET {{baseUrl}}/api/stores/{{storeId}}/statistics/popular-products
Authorization: {{ownerToken}}

### Get product by ID (internal)
GET {{baseUrl}}/internal/products/{{productId}}

### Increment product popularity (internal)
PUT {{baseUrl}}/internal/products/{{productId}}/popularity?delta=1
