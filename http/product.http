@baseUrl = http://localhost:8080
@storeId = 1
@productId = 1

### List products by store (public)
POST {{baseUrl}}/api/stores/products/list
Authorization: {{customerToken}}
Content-Type: application/json

{
  "storeId": {{storeId}}
}

### Get product by ID (public)
POST {{baseUrl}}/api/stores/products/find
Authorization: {{customerToken}}
Content-Type: application/json

{
  "storeId": {{storeId}},
  "productId": {{productId}}
}

### Create product - 후라이드 치킨 (OWNER)
POST {{baseUrl}}/api/stores/products
Authorization: {{ownerToken}}
Content-Type: application/json

{
  "storeId": {{storeId}},
  "name": "후라이드 치킨",
  "description": "바삭바삭한 정통 후라이드 치킨입니다.",
  "price": 18000,
  "productPictureUrl": null
}

### Create product - 양념 치킨 (OWNER)
POST {{baseUrl}}/api/stores/products
Authorization: {{ownerToken}}
Content-Type: application/json

{
  "storeId": {{storeId}},
  "name": "양념 치킨",
  "description": "달콤하고 매콤한 양념 치킨입니다.",
  "price": 19000,
  "productPictureUrl": null
}

### Update product (OWNER)
PUT {{baseUrl}}/api/stores/products
Authorization: {{ownerToken}}
Content-Type: application/json

{
  "storeId": {{storeId}},
  "productId": {{productId}},
  "name": "후라이드 치킨 (특대)",
  "description": "바삭바삭한 정통 후라이드 치킨 특대 사이즈입니다.",
  "price": 21000,
  "productPictureUrl": "https://example.com/chicken.jpg"
}

### Deactivate product (OWNER)
PUT {{baseUrl}}/api/stores/products/deactivate
Authorization: {{ownerToken}}
Content-Type: application/json

{
  "storeId": {{storeId}},
  "productId": {{productId}}
}

### Get popular products for store (OWNER)
POST {{baseUrl}}/api/stores/statistics/popular-products
Authorization: {{ownerToken}}
Content-Type: application/json

{
  "storeId": {{storeId}}
}

### Increment product popularity (OWNER)
PUT {{baseUrl}}/api/stores/products/popularity
Authorization: {{ownerToken}}
Content-Type: application/json

{
  "storeId": {{storeId}},
  "productId": {{productId}},
  "delta": 1
}

###

# =============================================================================
# HMAC Verification — store-service :8082  (product endpoint)
# =============================================================================

### HMAC-1: Direct to backend — no headers → 401 Missing HMAC headers
POST http://localhost:8082/api/stores/products/list
Content-Type: application/json

{
  "storeId": {{storeId}}
}

###

### HMAC-2: Through BFF — signed automatically → 200
POST http://localhost:8080/api/stores/products/list
Content-Type: application/json

{
  "storeId": {{storeId}}
}

###

### HMAC-3: Direct to backend — valid timestamp, wrong signature → 401 Invalid HMAC signature
< {%
  request.variables.set("nowMs", Date.now().toString());
%}
POST http://localhost:8082/api/stores/products/list
Content-Type: application/json
X-Bff-Timestamp: {{nowMs}}
X-Bff-Signature: deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef

{
  "storeId": {{storeId}}
}

###

### HMAC-4: Direct to backend — expired timestamp → 401 Request expired
POST http://localhost:8082/api/stores/products/list
Content-Type: application/json
X-Bff-Timestamp: 1000000000000
X-Bff-Signature: anything

{
  "storeId": {{storeId}}
}
