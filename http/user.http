@baseUrl = http://localhost:8080

### Sign up - CUSTOMER
POST {{baseUrl}}/api/users/signup
Content-Type: application/json

{
  "email": "customer@example.com",
  "password": "password123",
  "phone": "010-1111-2222"
}

### Sign in - CUSTOMER
POST {{baseUrl}}/api/users/signin
Content-Type: application/json

{
  "email": "customer@example.com",
  "password": "password123"
}

> {%
client.global.set("customerToken", "Bearer " + response.body.accessToken);
%}

### Sign up - OWNER (for Store domain)
POST {{baseUrl}}/api/users/signup
Content-Type: application/json

{
  "email": "owner@example.com",
  "password": "password123",
  "phone": "010-3333-4444",
  "role": "OWNER"
}

### Sign in - OWNER
POST {{baseUrl}}/api/users/signin
Content-Type: application/json

{
  "email": "owner@example.com",
  "password": "password123"
}

> {%
client.global.set("ownerToken", "Bearer " + response.body.accessToken);
%}

### Sign up - ADMIN
POST {{baseUrl}}/api/users/signup
Content-Type: application/json

{
  "email": "admin@example.com",
  "password": "password123",
  "phone": "010-9999-0000",
  "role": "ADMIN"
}

### Sign in - ADMIN
POST {{baseUrl}}/api/users/signin
Content-Type: application/json

{
  "email": "admin@example.com",
  "password": "password123"
}

> {%
client.global.set("adminToken", "Bearer " + response.body.accessToken);
%}

### Suspend user (ADMIN only) — replace id with actual user ID
#PUT {{baseUrl}}/api/users/suspend
#Authorization: {{adminToken}}
#Content-Type: application/json
#
#{
#  "id": 1
#}

### Withdraw (self)
#PUT {{baseUrl}}/api/users/me/withdraw
#Authorization: {{customerToken}}

###

# =============================================================================
# HMAC Verification — user-service :8081
# =============================================================================

### HMAC-1: Direct to backend — no headers → 401 Missing HMAC headers
POST http://localhost:8081/api/users/signup
Content-Type: application/json

{
  "email": "hmac-test@example.com",
  "password": "password123",
  "role": "CUSTOMER"
}

###

### HMAC-2: Through BFF — signed automatically → 201 (or 409 if already registered)
POST http://localhost:8080/api/users/signup
Content-Type: application/json

{
  "email": "hmac-test@example.com",
  "password": "password123",
  "role": "CUSTOMER"
}

###

### HMAC-3: Direct to backend — valid timestamp, wrong signature → 401 Invalid HMAC signature
< {%
  request.variables.set("nowMs", Date.now().toString());
%}
POST http://localhost:8081/api/users/signup
Content-Type: application/json
X-Bff-Timestamp: {{nowMs}}
X-Bff-Signature: deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef

{
  "email": "hmac-test@example.com",
  "password": "password123",
  "role": "CUSTOMER"
}

###

### HMAC-4: Direct to backend — expired timestamp → 401 Request expired
POST http://localhost:8081/api/users/signup
Content-Type: application/json
X-Bff-Timestamp: 1000000000000
X-Bff-Signature: anything

{
  "email": "hmac-test@example.com",
  "password": "password123",
  "role": "CUSTOMER"
}
